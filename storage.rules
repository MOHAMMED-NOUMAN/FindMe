rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── missing_persons photos ────────────────────────────────────────────
    // Only phone-authenticated users can upload. Max 5 MB. Images only.
    match /missing_persons/{refId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── found_persons photos ──────────────────────────────────────────────
    match /found_persons/{refId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── rescuer_requests ID-proof uploads ─────────────────────────────────
    // Registration happens BEFORE the user authenticates, so auth is not
    // available here. We restrict by size (5 MB) and content type only.
    match /rescuer_requests/{email}/{fileName} {
      allow read: if false; // admin downloads via Firebase Console / SDK
      allow write: if request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }

    // Default deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
